<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<packageSources>
		<clear/>
		<add key="HeadSoft" value="https://pkgs.dev.azure.com/headsoft-dev/_packaging/HeadSoft/nuget/v3/index.json" />
		<add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
	</packageSources>

	<packageSourceMapping>
		<packageSource key="HeadSoft">
			<package pattern="HeadSoft.*" />
		</packageSource>
		<packageSource key="nuget.org">
			<package pattern="*" />
		</packageSource>
	</packageSourceMapping>

</configuration>