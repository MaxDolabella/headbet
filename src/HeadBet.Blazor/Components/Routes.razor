<Router AppAssembly="@typeof(Program).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)">
            <NotAuthorized>
                <RedirectToLogin />
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="@routeData" Selector="h1, h2" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(Layout.MainLayout)">
            <MudContainer MaxWidth="MaxWidth.Medium" Class="my-12 text-center">
                <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Size="Size.Large" Color="Color.Tertiary" Style="font-size: 6rem;" />
                <MudText Typo="Typo.h3" Class="mt-6">Página não encontrada</MudText>
                <MudText Class="mt-2 mud-text-secondary">A URL que você acessou não existe ou foi removida.</MudText>
                <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-6" StartIcon="@Icons.Material.Filled.Home">
                    Voltar para o início
                </MudButton>
            </MudContainer>
        </LayoutView>
    </NotFound>
</Router>
