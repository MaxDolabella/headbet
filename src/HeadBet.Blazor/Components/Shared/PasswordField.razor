@* Campo de senha com botão de revelar (olho). Renderiza um <input name="@Name">
   de verdade, então funciona dentro dos <form method="post"> de auth (SSR). *@

<MudTextField T="string"
              Label="@Label"
              name="@Name"
              Variant="Variant.Outlined"
              InputType="@_inputType"
              Required="@Required"
              HelperText="@HelperText"
              Adornment="Adornment.End"
              AdornmentIcon="@_icon"
              OnAdornmentClick="Toggle"
              AdornmentAriaLabel="@(_shown ? "Ocultar senha" : "Mostrar senha")" />

@code {
    [Parameter, EditorRequired] public string Name { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public bool Required { get; set; } = true;
    [Parameter] public string? HelperText { get; set; }

    private InputType _inputType = InputType.Password;
    private string _icon = Icons.Material.Filled.VisibilityOff;
    private bool _shown;

    private void Toggle()
    {
        _shown = !_shown;
        _inputType = _shown ? InputType.Text : InputType.Password;
        _icon = _shown ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    }
}
