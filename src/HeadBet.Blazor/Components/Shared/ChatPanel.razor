@* Painel de chat reutilizável. Serve o mural do bolão (Scope=PoolGeneral) e os
   comentários de um jogo (Scope=Match). Carrega o histórico na inicialização e
   recebe mensagens novas em tempo real via IChatBroadcaster (Blazor Server, um
   circuito por usuário — sem SignalR dedicado). *@
@implements IDisposable
@inject IBus Bus
@inject IChatBroadcaster Broadcaster
@inject IUserContext UserContext
@inject ISnackbar Snackbar
@inject INotificationTranslator Translator

<MudPaper Elevation="0" Outlined="true" Class="pa-3">
    <div class="hb-chat-messages" style="@($"max-height:{MaxHeightPx}px;overflow-y:auto;")">
        @if (_messages.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary py-2">
                Nenhuma mensagem ainda. @(CanPost ? "Seja o primeiro a comentar." : null)
            </MudText>
        }
        else
        {
            @for (var i = 0; i < _messages.Count; i++)
            {
                var m = _messages[i];
                @if (i > 0)
                {
                    <MudDivider Class="my-2" />
                }
                <div class="hb-chat-msg">
                    <div class="d-flex align-center gap-2 mb-1">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary"><b>@m.UserName</b></MudText>
                        <span class="hb-chat-time mud-text-secondary">@m.CreatedAt.ToString("dd/MM HH:mm")</span>
                        @if (CanModerate)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small"
                                           Color="Color.Default" Class="ml-auto"
                                           OnClick="@(() => DeleteMessage(m.Id))" aria-label="Apagar mensagem" />
                        }
                    </div>
                    <MudText Typo="Typo.body2" Class="hb-chat-text" Style="white-space:pre-wrap;word-break:break-word;">@m.Text</MudText>
                </div>
            }
        }
    </div>

    @if (CanPost)
    {
        <div class="d-flex align-center gap-2 mt-2">
            <MudTextField @bind-Value="_draft" Immediate="true" OnKeyDown="OnKeyDown"
                          Placeholder="Escreva uma mensagem..." Variant="Variant.Outlined"
                          Margin="Margin.Dense" MaxLength="500" Lines="1" Class="flex-grow-1"
                          Disabled="_sending" />
            <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary"
                           OnClick="Send" Disabled="@(_sending || string.IsNullOrWhiteSpace(_draft))"
                           aria-label="Enviar" />
        </div>
    }
    else
    {
        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
            Apenas membros do bolão podem comentar.
        </MudText>
    }
</MudPaper>

@code {
    [Parameter, EditorRequired] public Guid PoolId { get; set; }
    [Parameter] public ChatScope Scope { get; set; } = ChatScope.PoolGeneral;
    [Parameter] public Guid? MatchId { get; set; }
    [Parameter] public bool CanPost { get; set; }
    [Parameter] public bool CanModerate { get; set; }
    [Parameter] public int MaxHeightPx { get; set; } = 300;

    private readonly List<ChatMessageViewModel> _messages = [];
    private string _draft = string.Empty;
    private bool _sending;
    private IDisposable? _subscription;

    private string ContextKey => ChatContextKeys.For(Scope, PoolId, MatchId);

    protected override async Task OnInitializedAsync()
    {
        var messages = await Bus.SendAsync(new ListChatMessagesQuery(PoolId, Scope, MatchId));
        _messages.Clear();
        if (messages is not null)
            _messages.AddRange(messages);
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        // OnAfterRender só dispara no render interativo (não no prerender),
        // então a inscrição não duplica.
        if (firstRender)
            _subscription = Broadcaster.Subscribe(ContextKey, OnChatEvent);

        return Task.CompletedTask;
    }

    private Task OnChatEvent(ChatEvent evt)
    {
        if (evt.IsDelete)
        {
            _messages.RemoveAll(m => m.Id == evt.DeletedMessageId);
        }
        else if (evt.Message is not null && _messages.All(m => m.Id != evt.Message.Id))
        {
            _messages.Add(evt.Message);
        }

        return InvokeAsync(StateHasChanged);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await Send();
    }

    private async Task Send()
    {
        var text = _draft?.Trim() ?? string.Empty;
        if (_sending || string.IsNullOrEmpty(text))
            return;

        _sending = true;
        try
        {
            var result = await Bus.SendAsync(new PostChatMessageCommand
            {
                PoolId = PoolId,
                Scope = Scope,
                MatchId = MatchId,
                Text = text,
            });

            if (!result.IsValid)
            {
                foreach (var n in result.Notifications ?? [])
                    Snackbar.AddNotification(n, Translator);
                return;
            }

            // A mensagem chega de volta pelo broadcaster (inclusive pra este usuário).
            _draft = string.Empty;
        }
        finally
        {
            _sending = false;
        }
    }

    private async Task DeleteMessage(Guid id)
    {
        var result = await Bus.SendAsync(new DeleteChatMessageCommand(id));
        if (!result.IsValid)
        {
            foreach (var n in result.Notifications ?? [])
                Snackbar.AddNotification(n, Translator);
        }
    }

    public void Dispose() => _subscription?.Dispose();
}
