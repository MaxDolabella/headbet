@using HeadBet.Core.Domain.Enums

<CollapsibleCard Title="Prêmios" Icon="@Icons.Material.Filled.EmojiEvents">
        @if (CollectedAmount is { } collected)
        {
            <div class="d-flex justify-content-between align-center mb-3" style="gap:1.5rem;">
                <span class="mud-text-secondary">Valor arrecadado</span>
                <MudText Typo="Typo.h6" Color="Color.Success" Class="ma-0">R$ @collected.ToString("N2")</MudText>
            </div>
            <MudDivider Class="mb-3" />
        }
        @if (Prizes.Count == 0)
        {
            <MudText Class="mud-text-secondary">Sem prêmios configurados.</MudText>
        }
        else
        {
            <MudSimpleTable Hover="true" Dense="true" Style="background:transparent;">
                <thead>
                    <tr>
                        <th>Posição</th>
                        @if (Mode == PrizeMode.Percentage)
                        {
                            <th class="text-end">% do bolo</th>
                        }
                        else
                        {
                            <th class="text-end">Valor fixo</th>
                        }
                        @if (ShowCalculated)
                        {
                            <th class="text-end">Valor (R$)</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Prizes.OrderBy(p => p.Position))
                    {
                        <tr>
                            <td>@p.Position&ordm;</td>
                            <td class="text-end">
                                @if (Mode == PrizeMode.Percentage)
                                {
                                    @($"{p.Percentage:N1}%")
                                }
                                else
                                {
                                    @($"R$ {p.FixedAmount:N2}")
                                }
                            </td>
                            @if (ShowCalculated)
                            {
                                <td class="text-end">R$ @p.CalculatedAmount.ToString("N2")</td>
                            }
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
</CollapsibleCard>

@code {
    [Parameter, EditorRequired] public List<PrizeItemViewModel> Prizes { get; set; } = [];
    [Parameter] public PrizeMode Mode { get; set; } = PrizeMode.Percentage;
    [Parameter] public bool ShowCalculated { get; set; }
    [Parameter] public decimal? CollectedAmount { get; set; }
}
