@* Exibe um time de forma padronizada.
   Mandante (Home): "Nome {bandeira}" alinhado à direita.
   Visitante (Away): "{bandeira} Nome" alinhado à esquerda.
   Responsivo: em telas estreitas a bandeira some e fica só o NOME. *@

<span class="hb-team @(Home ? "home" : "away")" title="@Name">
    @if (Home)
    {
        <span class="hb-team-label">
            <b class="hb-team-name">@Name</b>
        </span>
        @if (!string.IsNullOrWhiteSpace(FlagUrl))
        {
            <img class="hb-team-flag" src="@FlagUrl" alt="@Name" loading="lazy" decoding="async" />
        }
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(FlagUrl))
        {
            <img class="hb-team-flag" src="@FlagUrl" alt="@Name" loading="lazy" decoding="async" />
        }
        <span class="hb-team-label">
            <b class="hb-team-name">@Name</b>
        </span>
    }
</span>

@code {
    [Parameter] public string Name { get; set; } = string.Empty;
    [Parameter] public string FlagUrl { get; set; } = string.Empty;

    /// <summary>true = mandante (alinhado à direita); false = visitante (alinhado à esquerda).</summary>
    [Parameter] public bool Home { get; set; }
}
