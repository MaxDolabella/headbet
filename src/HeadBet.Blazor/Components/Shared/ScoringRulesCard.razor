@using HeadBet.Core.Domain.Enums

<CollapsibleCard Title="Regras de pontuação" Icon="@Icons.Material.Filled.Calculate">
    <MudSimpleTable Hover="true" Dense="true" Style="background:transparent;">
            <thead>
                <tr>
                    <th>Regra</th>
                    <th class="text-end">Pontos</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rule in Rules.OrderByDescending(r => r.Points))
                {
                    <tr>
                        <td>@LabelFor(rule.Type)</td>
                        <td class="text-end"><PointsBadge Type="rule.Type" Points="rule.Points" /></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
</CollapsibleCard>

@code {
    [Parameter, EditorRequired] public List<ScoringRuleItemViewModel> Rules { get; set; } = [];

    private static string LabelFor(ScoreType t) => t switch
    {
        ScoreType.ExactScore => "Placar exato",
        ScoreType.WinnerAndWinnerGoals => "Vencedor + gols do vencedor",
        ScoreType.WinnerAndDifference => "Vencedor + diferença de gols / empate",
        ScoreType.WinnerAndLoserGoals => "Vencedor + gols do perdedor",
        ScoreType.WinnerOnly => "Apenas vencedor",
        ScoreType.Consolation => "Consolação (errou o resultado)",
        ScoreType.NoBet => "Sem palpite",
        _ => t.ToString(),
    };
}
