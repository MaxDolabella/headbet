<MudDialog>
    <DialogContent>
        <MudText>@Message</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancelar</MudButton>
        <MudButton OnClick="Confirm" Color="@ConfirmColor" Variant="Variant.Filled">@ConfirmText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string Message { get; set; } = "Tem certeza?";
    [Parameter] public string ConfirmText { get; set; } = "Confirmar";
    [Parameter] public Color ConfirmColor { get; set; } = Color.Primary;

    private void Confirm() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}
