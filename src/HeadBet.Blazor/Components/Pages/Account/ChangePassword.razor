@page "/account/change-password"
@layout HeadBet.Blazor.Components.Layout.MainLayout
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Trocar senha — HeadBet</PageTitle>

<MudPaper Elevation="4" Class="hb-auth-card pa-6">
    <MudText Typo="Typo.h5" Class="mb-1"><MudIcon Icon="@Icons.Material.Filled.Password" /> Trocar senha</MudText>
    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">Informe a senha atual e escolha uma nova.</MudText>

    @if (!string.IsNullOrEmpty(Error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-3" Dense="true">@Error</MudAlert>
    }
    <form method="post" action="/account/change-password">
        <AntiforgeryToken />

        <MudStack Spacing="3">
            <PasswordField Name="currentPassword" Label="Senha atual" />
            <PasswordField Name="newPassword" Label="Nova senha" HelperText="Mínimo 6 caracteres." />
            <PasswordField Name="confirmPassword" Label="Confirmar nova senha" />
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                       FullWidth="true" StartIcon="@Icons.Material.Filled.Check">Salvar nova senha</MudButton>
        </MudStack>
    </form>
</MudPaper>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
}
