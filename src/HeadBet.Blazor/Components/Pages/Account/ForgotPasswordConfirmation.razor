@page "/account/forgot-password-confirmation"
@layout HeadBet.Blazor.Components.Layout.MainLayout
@attribute [AllowAnonymous]

<PageTitle>Verifique seu e-mail — HeadBet</PageTitle>

<MudPaper Elevation="4" Class="hb-auth-card pa-6 text-center">
    <MudIcon Icon="@Icons.Material.Filled.MarkEmailRead" Color="Color.Success" Style="font-size: 3rem;" />
    <MudText Typo="Typo.h5" Class="mt-2 mb-2">Verifique seu e-mail</MudText>
    <MudText Class="mud-text-secondary mb-4">
        Se o e-mail informado estiver cadastrado, enviamos um link para você redefinir sua senha.
        O link expira em 2 horas.
    </MudText>
    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-4">
        Não recebeu? Confira a caixa de spam ou
        <MudLink Href="/account/forgot-password">tente novamente</MudLink>.
    </MudText>
    <MudButton Href="/account/login" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
               StartIcon="@Icons.Material.Filled.Login">Voltar para o login</MudButton>
</MudPaper>
