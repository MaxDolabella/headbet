@page "/account/reset-password"
@layout HeadBet.Blazor.Components.Layout.MainLayout
@attribute [AllowAnonymous]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Redefinir senha — HeadBet</PageTitle>

<MudPaper Elevation="4" Class="hb-auth-card pa-6">
    <MudText Typo="Typo.h5" Class="mb-1"><MudIcon Icon="@Icons.Material.Filled.Password" /> Redefinir senha</MudText>
    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">Escolha uma nova senha para sua conta.</MudText>

    @if (!string.IsNullOrEmpty(Error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-3" Dense="true">@Error</MudAlert>
    }

    @if (string.IsNullOrWhiteSpace(Token))
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mb-3" Dense="true">
            Link de redefinição inválido. Solicite um novo.
        </MudAlert>
        <MudButton Href="/account/forgot-password" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true">
            Solicitar novo link
        </MudButton>
    }
    else
    {
        <form method="post" action="/account/reset-password">
            <AntiforgeryToken />
            <input type="hidden" name="token" value="@Token" />

            <MudStack Spacing="3">
                <PasswordField Name="newPassword" Label="Nova senha" HelperText="Mínimo 6 caracteres." />
                <PasswordField Name="confirmPassword" Label="Confirmar nova senha" />
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                           FullWidth="true" StartIcon="@Icons.Material.Filled.Check">Redefinir senha</MudButton>
            </MudStack>
        </form>
    }
</MudPaper>

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }
    [SupplyParameterFromQuery] public string? Error { get; set; }
}
