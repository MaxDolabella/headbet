@page "/account/forgot-password"
@layout HeadBet.Blazor.Components.Layout.MainLayout
@attribute [AllowAnonymous]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Recuperar senha — HeadBet</PageTitle>

<MudPaper Elevation="4" Class="hb-auth-card pa-6">
    <MudText Typo="Typo.h5" Class="mb-1"><MudIcon Icon="@Icons.Material.Filled.LockReset" /> Recuperar senha</MudText>
    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
        Informe o e-mail da sua conta. Se houver cadastro, enviaremos um link para criar uma nova senha.
    </MudText>

    @if (!string.IsNullOrEmpty(Error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-3" Dense="true">@Error</MudAlert>
    }

    <form method="post" action="/account/forgot-password">
        <AntiforgeryToken />

        <MudStack Spacing="3">
            <MudTextField T="string" Label="E-mail" Variant="Variant.Outlined" InputType="InputType.Email"
                          name="email" Value="@Email" Required="true" />
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                       FullWidth="true" StartIcon="@Icons.Material.Filled.Send">Enviar link</MudButton>
            <MudText Typo="Typo.caption" Class="text-center mud-text-secondary">
                Lembrou a senha? <MudLink Href="/account/login">Entrar</MudLink>
            </MudText>
        </MudStack>
    </form>
</MudPaper>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery] public string? Email { get; set; }
}
