@page "/join/{Code}"
@attribute [Authorize]
@inject IBus Bus
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Convite — HeadBet</PageTitle>

@if (_pool is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <PageHeader Title="@($"Convite: {_pool.Name}")" Icon="@Icons.Material.Filled.MarkEmailRead" Breadcrumbs="@_crumbs" HelpAnchor="entrar-bolao" />

    <MudPaper Elevation="3" Class="pa-6 mb-4" Style="max-width:680px;margin:auto;">
        <MudText Typo="Typo.h5" Class="mb-2">@_pool.Name</MudText>
        @if (!string.IsNullOrWhiteSpace(_pool.Description))
        {
            <MudText Class="mud-text-secondary mb-4">@_pool.Description</MudText>
        }

        <MudGrid Class="mb-4">
            <MudItem xs="6"><MudText Typo="Typo.caption">Visibilidade</MudText>
                <PoolVisibilityBadge IsPublic="@_pool.IsPublic" /></MudItem>
            <MudItem xs="6"><MudText Typo="Typo.caption">Tipo</MudText>
                <div class="d-flex align-items-center" style="gap:.5rem;">
                    <PoolPaidBadge IsPaid="@_pool.IsPaid" />
                    @if (_pool.IsPaid && _pool.EntryFee.HasValue)
                    {
                        <span>R$ @_pool.EntryFee.Value.ToString("N2")</span>
                    }
                </div></MudItem>
            <MudItem xs="6"><MudText Typo="Typo.caption">Membros ativos</MudText>
                <MudText>@_pool.MemberCount</MudText></MudItem>
        </MudGrid>

        @if (!_pool.IsActive)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-3">
                Este bolão não está ativo no momento.
            </MudAlert>
            <MudButton Variant="Variant.Text" Href="/pools">Voltar</MudButton>
        }
        else if (_pool.MyStatus == PoolMemberStatus.Active)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3">
                Você já participa deste bolão.
            </MudAlert>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@($"/pools/{_pool.Id}")"
                       StartIcon="@Icons.Material.Filled.Visibility">Ver bolão</MudButton>
        }
        else
        {
            <MudText Class="mb-3">
                @(_pool.MyStatus switch
                {
                    PoolMemberStatus.Pending => "Sua solicitação está pendente. Ao aceitar este convite, seu vínculo será ativado imediatamente.",
                    PoolMemberStatus.Inactive => "Seu vínculo anterior com este bolão está inativo. Ao aceitar este convite, será reativado.",
                    _ => "Ao aceitar este convite, você entrará no bolão como participante.",
                })
            </MudText>
            <div class="d-flex" style="gap:.5rem;">
                <MudButton Variant="Variant.Text" Href="/pools">Cancelar</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Check"
                           OnClick="Confirm" Disabled="_busy">
                    @(_busy ? "Entrando..." : "Aceitar convite e entrar")
                </MudButton>
            </div>
        }
    </MudPaper>
}

@code {
    [Parameter] public string Code { get; set; } = string.Empty;

    private PoolInviteViewModel? _pool;
    private bool _busy;
    private List<BreadcrumbItem> _crumbs = new();

    protected override async Task OnInitializedAsync()
    {
        _pool = await Bus.SendAsync(new GetPoolInviteInfoQuery(Code));
        if (_pool is null)
        {
            Nav.NavigateTo("/pools");
            return;
        }
        _crumbs =
        [
            new("Home", "/"),
            new("Bolões", "/pools"),
            new($"Convite: {_pool.Name}", null, disabled: true),
        ];
    }

    private async Task Confirm()
    {
        _busy = true;
        try
        {
            var result = await Bus.SendAsync(new JoinPoolCommand { PoolId = _pool!.Id, Source = JoinSource.InviteLink });
            if (!result.IsValid)
            {
                Snackbar.Add(result.Notifications?.FirstOrDefault()?.Message ?? "Não foi possível entrar no bolão.", Severity.Error);
                return;
            }
            Snackbar.Add("Você entrou no bolão!", Severity.Success);
            Nav.NavigateTo($"/pools/{_pool!.Id}");
        }
        finally { _busy = false; }
    }
}
