@page "/pools/create"
@attribute [Authorize]
@inject IBus Bus
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject INotificationTranslator Translator

<PageTitle>Novo bolão — HeadBet</PageTitle>

<PageHeader Title="Criar bolão" Icon="@Icons.Material.Filled.AddCircle" Breadcrumbs="@_crumbs" HelpAnchor="criar-bolao" />

<MudForm @ref="_form" Model="_model">
    <MudPaper Elevation="2" Class="pa-6 mb-4">
        <MudText Typo="Typo.h6" Class="mb-4"><MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" /> Dados do bolão</MudText>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_model.Name" Label="Nome" Variant="Variant.Outlined" Required="true" />
            <MudTextField @bind-Value="_model.Description" Label="Descrição" Variant="Variant.Outlined" Lines="3" />

            <MudSwitch T="bool" @bind-Value="_model.IsPaid" Label="Bolão pago" Color="Color.Warning" />

            @if (_model.IsPaid)
            {
                <MoneyField @bind-Value="EntryFeeValue" Label="Taxa de inscrição" />
            }

            <MudSwitch T="bool" @bind-Value="_model.IsPublic" Label="Bolão público"
                       Color="Color.Info" />
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                Bolões públicos aparecem na lista de todos os usuários. Privados só são acessíveis via link de convite.
            </MudText>

            <MudSwitch T="bool" @bind-Value="_model.AutoAccept" Label="Aceitar novos membros automaticamente"
                       Color="Color.Primary" />
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                Aplica-se a quem clicar em "Entrar" na listagem de bolões públicos. Convites por link sempre entram direto.
            </MudText>

            <MudSwitch T="bool" @bind-Value="_model.IsActive" Label="Ativo" Color="Color.Success" />
        </MudStack>
    </MudPaper>

    <MudPaper Elevation="2" Class="pa-6 mb-4">
        <MudText Typo="Typo.h6" Class="mb-4"><MudIcon Icon="@Icons.Material.Filled.Calculate" Size="Size.Small" /> Regras de pontuação</MudText>
        <MudStack Spacing="2">
            @foreach (var rule in _model.ScoringRules)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudText Class="flex-grow-1 ma-0">@LabelFor(rule.Type)</MudText>
                    <div style="width:120px; flex:0 0 120px;">
                        <MudNumericField T="int" @bind-Value="rule.Points" Min="0" Max="100"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                    </div>
                </MudStack>
            }
        </MudStack>
    </MudPaper>

    @if (_model.IsPaid)
    {
        <MudPaper Elevation="2" Class="pa-6 mb-4">
            <MudText Typo="Typo.h6" Class="mb-4"><MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Size="Size.Small" /> Premiação</MudText>
            <MudStack Spacing="2">
                @for (var i = 0; i < _model.Prizes.Count; i++)
                {
                    var idx = i;
                    var prize = _model.Prizes[idx];
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <MudText Class="flex-grow-1 ma-0">@prize.Position&ordm; lugar</MudText>
                        <div style="width:160px; flex:0 0 160px;">
                            <MudNumericField T="decimal?" @bind-Value="prize.Percentage" Min="0m" Max="100m" Step="1m"
                                             Variant="Variant.Outlined" Margin="Margin.Dense" Format="N2" Culture="@_brCulture"
                                             FullWidth="true" Adornment="Adornment.End" AdornmentText="%" />
                        </div>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => RemovePrize(idx))" Disabled="@(_model.Prizes.Count <= 1)" />
                    </MudStack>
                }
                <div>
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add" OnClick="AddPrize">
                        Adicionar posição
                    </MudButton>
                </div>
            </MudStack>
        </MudPaper>
    }

    <div class="d-flex" style="gap:.5rem;">
        <MudButton Variant="Variant.Text" Href="/pools">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Check"
                   OnClick="Submit" Disabled="_busy">
            @(_busy ? "Salvando..." : "Criar bolão")
        </MudButton>
    </div>
</MudForm>

@code {
    private MudForm _form = default!;
    private bool _busy;
    private decimal? _entryFee;
    private readonly System.Globalization.CultureInfo _brCulture = new("pt-BR");
    private PoolFormViewModel _model = new();

    private decimal EntryFeeValue
    {
        get => _entryFee ?? 0m;
        set => _entryFee = value;
    }

    private static readonly List<BreadcrumbItem> _crumbs =
    [
        new("Home", "/"),
        new("Bolões", "/pools"),
        new("Novo", null, disabled: true),
    ];

    private void AddPrize()
    {
        _model.Prizes.Add(new PrizeItemViewModel { Position = _model.Prizes.Count + 1 });
    }

    private void RemovePrize(int idx)
    {
        _model.Prizes.RemoveAt(idx);
        for (var i = 0; i < _model.Prizes.Count; i++)
            _model.Prizes[i].Position = i + 1;
    }

    private async Task Submit()
    {
        _busy = true;
        try
        {
            var cmd = new CreatePoolCommand
            {
                Name = _model.Name,
                Description = _model.Description,
                IsPaid = _model.IsPaid,
                EntryFee = _model.IsPaid ? _entryFee : null,
                AutoAccept = _model.AutoAccept,
                IsActive = _model.IsActive,
                IsPublic = _model.IsPublic,
                ScoringRules = _model.ScoringRules,
                Prizes = _model.IsPaid ? _model.Prizes : [],
            };
            var result = await Bus.SendAsync(cmd);

            if (!result.IsValid)
            {
                foreach (var n in result.Notifications ?? [])
                    Snackbar.AddNotification(n, Translator);
                return;
            }

            Snackbar.Add("Bolão criado com sucesso.", Severity.Success);
            Nav.NavigateTo($"/pools/{result.Data}");
        }
        finally { _busy = false; }
    }

    private static string LabelFor(ScoreType t) => t switch
    {
        ScoreType.ExactScore => "Placar exato",
        ScoreType.WinnerAndWinnerGoals => "Vencedor + gols do vencedor",
        ScoreType.WinnerAndDifference => "Vencedor + diferença de gols / empate",
        ScoreType.WinnerAndLoserGoals => "Vencedor + gols do perdedor",
        ScoreType.WinnerOnly => "Apenas vencedor",
        ScoreType.Consolation => "Consolação (errou o resultado)",
        ScoreType.NoBet => "Sem palpite",
        _ => t.ToString(),
    };
}
