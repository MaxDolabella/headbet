@page "/pools/{Id:guid}/members"
@attribute [Authorize]
@using Headsoft.Core
@using Headsoft.Messaging.Abstractions.Commands
@inject IBus Bus
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService Dialog

<PageTitle>Participantes — HeadBet</PageTitle>

@if (_vm is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <PageHeader Title="Participantes" Icon="@Icons.Material.Filled.People"
                Subtitle="@($"Bolão: {_vm.PoolName}")" Breadcrumbs="@_crumbs" HelpAnchor="participantes" />

    <MudCard Elevation="2" Class="mb-4">
        <MudCardHeader><CardHeaderContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Size="Size.Small" /> Solicitações pendentes (@Pending.Count)
            </MudText>
        </CardHeaderContent></MudCardHeader>
        <MudCardContent>
            @if (Pending.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Nenhuma solicitação pendente.</MudAlert>
            }
            else
            {
                <MudSimpleTable Hover="true" Dense="true" Style="background:transparent;">
                    <tbody>
                    @foreach (var m in Pending)
                    {
                        <tr>
                            <td>@m.UserName</td>
                            <td class="mud-text-secondary">@m.JoinedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end">
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                                           StartIcon="@Icons.Material.Filled.Check" Disabled="_busy"
                                           OnClick="@(() => Approve(m))">Aprovar</MudButton>
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" Class="ms-2"
                                           StartIcon="@Icons.Material.Filled.Close" Disabled="_busy"
                                           OnClick="@(() => Reject(m))">Recusar</MudButton>
                            </td>
                        </tr>
                    }
                    </tbody>
                </MudSimpleTable>
            }
        </MudCardContent>
    </MudCard>

    <MudCard Elevation="2" Class="mb-4">
        <MudCardHeader><CardHeaderContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" /> Participantes ativos (@Active.Count)
            </MudText>
        </CardHeaderContent></MudCardHeader>
        <MudCardContent>
            <MudSimpleTable Hover="true" Dense="true" Style="background:transparent;">
                <tbody>
                @foreach (var m in Active)
                {
                    <tr>
                        <td>
                            @m.UserName
                            @if (m.IsCurrentUser)
                            {
                                <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Text">você</MudChip>
                            }
                        </td>
                        <td><PoolMemberRoleBadge Status="@m.Status" Role="@m.Role" /></td>
                        <td class="text-end">
                            @if (m.Role != PoolMemberRole.Admin && !m.IsCurrentUser)
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                                           StartIcon="@Icons.Material.Filled.Block" Disabled="_busy"
                                           OnClick="@(() => Deactivate(m))">Desativar</MudButton>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </MudSimpleTable>
        </MudCardContent>
    </MudCard>

    @if (Inactive.Count > 0)
    {
        <MudCard Elevation="2" Class="mb-4">
            <MudCardHeader><CardHeaderContent>
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.PersonOff" Size="Size.Small" /> Inativos (@Inactive.Count)
                </MudText>
            </CardHeaderContent></MudCardHeader>
            <MudCardContent>
                <MudSimpleTable Hover="true" Dense="true" Style="background:transparent;">
                    <tbody>
                    @foreach (var m in Inactive)
                    {
                        <tr>
                            <td>@m.UserName</td>
                            <td class="text-end">
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                           StartIcon="@Icons.Material.Filled.Replay" Disabled="_busy"
                                           OnClick="@(() => Reactivate(m))">Reativar</MudButton>
                            </td>
                        </tr>
                    }
                    </tbody>
                </MudSimpleTable>
            </MudCardContent>
        </MudCard>
    }

    <div class="mt-3">
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" Href="@($"/pools/{Id}")">
            Voltar ao bolão
        </MudButton>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private PoolMembersAdminViewModel? _vm;
    private bool _busy;
    private List<BreadcrumbItem> _crumbs = new();

    private List<PoolMemberItemViewModel> Pending =>
        _vm?.Members.Where(m => m.Status == PoolMemberStatus.Pending).ToList() ?? [];
    private List<PoolMemberItemViewModel> Active =>
        _vm?.Members.Where(m => m.Status == PoolMemberStatus.Active).ToList() ?? [];
    private List<PoolMemberItemViewModel> Inactive =>
        _vm?.Members.Where(m => m.Status == PoolMemberStatus.Inactive).ToList() ?? [];

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _vm = await Bus.SendAsync(new GetPoolMembersAdminQuery(Id));
        if (_vm is null)
        {
            Snackbar.Add("Bolão não encontrado ou você não é admin.", Severity.Error);
            Nav.NavigateTo("/pools");
            return;
        }
        _crumbs =
        [
            new("Home", "/"),
            new("Bolões", "/pools"),
            new(_vm.PoolName, $"/pools/{Id}"),
            new("Participantes", null, disabled: true),
        ];
    }

    private Task Approve(PoolMemberItemViewModel m)
        => Run(new ApprovePoolMemberCommand { PoolId = Id, UserId = m.UserId }, $"{m.UserName} aprovado.");

    private Task Reactivate(PoolMemberItemViewModel m)
        => Run(new ReactivatePoolMemberCommand { PoolId = Id, UserId = m.UserId }, $"{m.UserName} reativado.");

    private async Task Reject(PoolMemberItemViewModel m)
    {
        if (!await Confirm($"Recusar a solicitação de {m.UserName}? O registro será removido.", "Recusar"))
            return;
        await Run(new RejectPoolMemberCommand { PoolId = Id, UserId = m.UserId }, $"Solicitação de {m.UserName} recusada.");
    }

    private async Task Deactivate(PoolMemberItemViewModel m)
    {
        if (!await Confirm($"Desativar {m.UserName}? Ele deixará de participar do ranking.", "Desativar"))
            return;
        await Run(new DeactivatePoolMemberCommand { PoolId = Id, UserId = m.UserId }, $"{m.UserName} desativado.");
    }

    private async Task<bool> Confirm(string message, string yesText)
    {
        var ok = await Dialog.ShowMessageBoxAsync("Confirmação", message, yesText: yesText, cancelText: "Cancelar");
        return ok == true;
    }

    private async Task Run(CommandBase<OperationResult> command, string successMsg)
    {
        _busy = true;
        try
        {
            var result = await Bus.SendAsync(command);
            if (!result.IsValid)
            {
                Snackbar.Add(result.Notifications?.FirstOrDefault()?.Details ?? "Erro ao processar a ação.", Severity.Error);
                return;
            }
            Snackbar.Add(successMsg, Severity.Success);
            await Load();
        }
        finally { _busy = false; }
    }
}
