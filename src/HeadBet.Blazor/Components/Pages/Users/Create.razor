@page "/users/create"
@attribute [Authorize(Roles = Roles.ADMIN)]
@inject IBus Bus
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject INotificationTranslator Translator

<PageTitle>Novo usuário — HeadBet</PageTitle>

<PageHeader Title="Novo usuário" Icon="@Icons.Material.Filled.PersonAdd" Breadcrumbs="@_crumbs" HelpAnchor="usuarios" />

<MudPaper Elevation="2" Class="pa-6" Style="max-width:560px;">
    <MudStack Spacing="3">
        <MudTextField @bind-Value="_model.Name" Label="Nome" Variant="Variant.Outlined" Required="true" />
        <MudTextField @bind-Value="_model.Email" Label="E-mail" InputType="InputType.Email" Variant="Variant.Outlined" Required="true" />
        <MudTextField @bind-Value="_model.Password" Label="Senha" InputType="InputType.Password" Variant="Variant.Outlined" Required="true" />
        <div class="d-flex" style="gap:.5rem;">
            <MudButton Variant="Variant.Text" Href="/users">Cancelar</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Check"
                       OnClick="Submit" Disabled="_busy">Salvar</MudButton>
        </div>
    </MudStack>
</MudPaper>

@code {
    private UserFormViewModel _model = new();
    private bool _busy;
    private static readonly List<BreadcrumbItem> _crumbs =
    [
        new("Home", "/"),
        new("Usuários", "/users"),
        new("Novo", null, disabled: true),
    ];

    private async Task Submit()
    {
        _busy = true;
        try
        {
            var cmd = new CreateUserCommand
            {
                Name = _model.Name,
                Email = _model.Email,
                Password = _model.Password ?? string.Empty,
            };
            var result = await Bus.SendAsync(cmd);
            if (!result.IsValid)
            {
                foreach (var n in result.Notifications ?? [])
                    Snackbar.AddNotification(n, Translator);
                return;
            }
            Snackbar.Add("Usuário criado.", Severity.Success);
            Nav.NavigateTo("/users");
        }
        finally { _busy = false; }
    }
}
